# ==========================================
# OpenViking Core Configuration
# ==========================================
# OpenViking Root Key (用于全局超级管理)
OPENVIKING_ROOT_KEY=<your-openviking-root-key>
# OpenViking API 地址
OPENVIKING_API_URL=http://<your-openviking-api-ip>:<port>
# OpenViking Key (用于服务间调用/租户级权限)
OPENVIKING_KEY=<your-openviking-key>

# ==========================================
# Network Proxy Configuration (Optional)
# ==========================================
# 代理配置，通常在本地开发需要访问外部API时使用
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# NO_PROXY=192.168.3.77,127.0.0.1,localhost

# ==========================================
# Supabase Configuration (Decoupled for now)
# ==========================================
# TODO: 未来集成 Supabase 时，请取消下面注释并填入正确信息
# NEXT_PUBLIC_SUPABASE_URL=http://<your-supabase-ip>:<port>
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>
